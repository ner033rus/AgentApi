[Unit]
Description=AgentAPI system metrics (CPU/RAM/GPU, Ollama)
After=network.target

[Service]
Type=simple
# Смените User и пути при необходимости (копия проекта должна совпадать с WorkingDirectory).
User=root
WorkingDirectory=/AgentAPI
Environment=PYTHONPATH=/AgentAPI
Environment=AGENT_API_HOST=0.0.0.0
Environment=AGENT_API_PORT=8765
ExecStart=/AgentAPI/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8765 --app-dir /AgentAPI
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
